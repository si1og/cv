---
import { EDUCATION } from "~/consts";
---

<section class="mb-8" aria-labelledby="education-heading">
    <div class="bg-[#1b1b1b] border border-[#2c2c2c] rounded-2xl p-5">
        <div
            class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1"
        >
            <h2 id="education-heading" class="text-lg font-bold text-[#d5d5d5]">
                {EDUCATION.university}
            </h2>
            <time class="text-sm text-[#a1a1a1]">{EDUCATION.period}</time>
        </div>
        <p class="text-[#a1a1a1] font-medium mb-4">
            <span class="italic">{EDUCATION.program}</span>
            <a
                href="https://github.com/si1og/poly"
                target="_blank"
                class="hover:text-[#d5d5d5]"
                >(Мой университетский моно-репо ↗)</a
            >
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {
                EDUCATION.details.map((item) => (
                    <li class="flex items-center gap-2 text-[#a1a1a1] text-sm">
                        <span
                            class="w-1.5 h-1.5 rounded-full bg-[#b47ff8] shrink-0"
                            aria-hidden="true"
                        />
                        {item}
                    </li>
                ))
            }
        </ul>
    </div>
</section>
